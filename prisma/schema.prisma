datasource db {
  provider = "postgresql"
    url = env("DATABASE_URL")

}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  name      String?
  createdAt DateTime   @default(now())
  queries   QueryLog[]
  reports   Report[]
}

model QueryLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  promptText  String
  modelUsed   String
  tokenCount  Int
  carbonGrams Float
  waterMl     Float
  landCm2     Float
  createdAt   DateTime @default(now())
}

model Report {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month       String   // e.g. "2026-06"
  totalCarbon Float
  totalWater  Float
  totalLand   Float
  aiNarrative String
  createdAt   DateTime @default(now())
}
